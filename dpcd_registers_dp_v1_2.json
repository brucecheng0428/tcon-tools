[
  {
    "addr": "00000",
    "name": "DPCD_REV",
    "bits": "[7:4]=Major revision number; [3:0]=Minor revision number; 10h=Rev1.0, 11h=Rev1.1, 12h=Rev1.2",
    "access": "R",
    "notes": "DPCD revision number"
  },
  {
    "addr": "00001",
    "name": "MAX_LINK_RATE",
    "bits": "[7:0]=MAX_LINK_RATE (Value x 0.27Gbps/lane); 06h=1.62Gbps, 0Ah=2.7Gbps, 14h=5.4Gbps",
    "access": "R",
    "notes": "Maximum link rate of Main Link lanes"
  },
  {
    "addr": "00002",
    "name": "MAX_LANE_COUNT",
    "bits": "[4:0]=MAX_LANE_COUNT (1h=1-lane, 2h=2-lanes, 4h=4-lanes); [5]=RESERVED(Rev1.2); [6]=TPS3_SUPPORTED(Rev1.2); [7]=ENHANCED_FRAME_CAP",
    "access": "R",
    "notes": "Maximum number of lanes. TPS3_SUPPORTED mandatory for HBR2 downstream devices"
  },
  {
    "addr": "00003",
    "name": "MAX_DOWNSPREAD",
    "bits": "[0]=MAX_DOWNSPREAD (1=Up to 0.5% down-spread); [5:1]=RESERVED; [6]=NO_AUX_HANDSHAKE_LINK_TRAINING; [7]=RESERVED",
    "access": "R",
    "notes": "Down-spread support. 0.5% mandatory for DP v1.1+"
  },
  {
    "addr": "00004",
    "name": "NORP",
    "bits": "[0]=NORP (Number of Receiver Ports = Value+1); [7:1]=RESERVED",
    "access": "R",
    "notes": "Number of Receiver Ports. Max 2 for SST"
  },
  {
    "addr": "00005",
    "name": "DOWNSTREAMPORT_PRESENT",
    "bits": "[0]=DWN_STRM_PORT_PRESENT; [2:1]=DWN_STRM_PORT_TYPE (00=DP,01=VGA,10=DVI/HDMI,11=Others); [3]=FORMAT_CONVERSION(Rev1.1+); [4]=DETAILED_CAP_INFO_AVAILABLE(Rev1.1+); [7:5]=RESERVED",
    "access": "R",
    "notes": "Downstream port presence and type"
  },
  {
    "addr": "00006",
    "name": "MAIN_LINK_CHANNEL_CODING",
    "bits": "[0]=ANSI_8B10B; [7:1]=RESERVED",
    "access": "R",
    "notes": "Main Link channel coding support"
  },
  {
    "addr": "00007",
    "name": "DOWN_STREAM_PORT_COUNT",
    "bits": "[3:0]=DWN_STRM_PORT_COUNT; [5:4]=RESERVED; [6]=MSA_TIMING_PAR_IGNORED; [7]=OUI_Support",
    "access": "R",
    "notes": "Rev1.0: RESERVED. Rev1.1+: Downstream port count. OUI mandatory for DP1.2"
  },
  {
    "addr": "00008",
    "name": "RECEIVE_PORT0_CAP_0",
    "bits": "[0]=RESERVED; [1]=LOCAL_EDID_PRESENT; [2]=ASSOCIATED_TO_PRECEDING_PORT; [7:3]=RESERVED",
    "access": "R",
    "notes": "ReceiverPort0 Capability_0"
  },
  {
    "addr": "00009",
    "name": "RECEIVE_PORT0_CAP_1",
    "bits": "[7:0]=BUFFER_SIZE (BufferSize=(Value+1)*32 bytes/lane, max 8KB/lane)",
    "access": "R",
    "notes": "ReceiverPort0 Capability_1"
  },
  {
    "addr": "0000A",
    "name": "RECEIVE_PORT1_CAP_0",
    "bits": "Same as RECEIVE_PORT0_CAP_0",
    "access": "R",
    "notes": "ReceiverPort1 Capability_0. Reads 0s when Port1 not present"
  },
  {
    "addr": "0000B",
    "name": "RECEIVE_PORT1_CAP_1",
    "bits": "Same as RECEIVE_PORT0_CAP_1",
    "access": "R",
    "notes": "ReceiverPort1 Capability_1. Reads 0s when Port1 not present"
  },
  {
    "addr": "0000C",
    "name": "I2C_SPEED_CONTROL_CAP",
    "bits": "[7:0] bitmap: bit0=1Kbps, bit1=5Kbps, bit2=10Kbps, bit3=100Kbps, bit4=400Kbps, bit5=1Mbps, bit6=RSVD, bit7=RSVD",
    "access": "R",
    "notes": "I2C speed control capabilities. 00h if no physical I2C bus or no speed control"
  },
  {
    "addr": "0000D",
